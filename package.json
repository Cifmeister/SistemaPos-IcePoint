{
  "name": "sistemapos",
  "private": true,
  "version": "1.6.0",
  "main": "main/main.js",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "dev": "vite",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && node start-electron.js\"",
    "build": "vite build",
    "dist": "npm run build && electron-builder",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.open-gravity.sistemapos",
    "productName": "Sistema POS",
    "directories": {
      "output": "dist-electron"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Cifmeister",
        "repo": "SistemaPos-IcePoint"
      }
    ],
    "files": [
      "dist/**/*",
      "main/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "runAfterFinish": true
    }
  },
  "description": "Sistema POS Profesional IcePoint v1.6.0 - Auditoría de Caja y Cartola de Efectivo.",
  "author": "Arturo Cifuentes",
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "electron-updater": "^6.3.9",
    "firebase": "^10.13.0",
    "lucide-react": "^0.454.0",
    "node-thermal-printer": "^4.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "7zip-bin": "^5.2.0",
    "concurrently": "^9.1.2",
    "electron": "32.3.3",
    "electron-builder": "^24.13.3",
    "eslint": "^9.9.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.2.0",
    "vite": "^6.2.0",
    "wait-on": "^8.0.1"
  }
}
